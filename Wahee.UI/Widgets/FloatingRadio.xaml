<local:WaheeWidgetBase x:Class="Wahee.UI.Widgets.FloatingRadio"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:local="clr-namespace:Wahee.UI.Widgets"
                        Title="راديو وحي"
                        Height="70" Width="400"
                        WindowStartupLocation="Manual"
                        Topmost="False"
                        AllowsTransparency="True"
                        WindowStyle="None"
                        Background="Transparent"
                        FlowDirection="RightToLeft"
                        Opacity="0.5"
                        MouseEnter="Window_MouseEnter"
                        MouseLeave="Window_MouseLeave">
    
    <local:WaheeWidgetBase.Resources>
        <Storyboard x:Key="FadeFull">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="FadeDim">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.5"/>
        </Storyboard>
    </local:WaheeWidgetBase.Resources>

    <Border Background="{DynamicResource BackgroundMainBrush}" CornerRadius="35" Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="15,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Play Button Only -->
            <Button x:Name="PlayPauseBtn" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource AccentBrush}" 
                    Width="40" Height="40" Click="PlayPause_Click">
                <Path x:Name="PlayPauseIcon" Data="{StaticResource PlayIconGeometry}" Fill="White" Stretch="Uniform" Width="16" Height="16"/>
            </Button>

            <!-- Radio Info -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                <TextBlock x:Name="StationNameTxt" Text="إذاعة القرآن الكريم من القاهرة" Foreground="{DynamicResource TextForegroundBrush}" 
                           FontSize="12" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontFamily="Cairo"/>
                <TextBlock x:Name="StatusTxt" Text="متوقف" Foreground="{DynamicResource TextHeaderBrush}" FontSize="10"/>
            </StackPanel>

            <!-- Volume Slider -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <Path Data="{StaticResource VolumeIconGeometry}" Fill="#88FFFFFF" Stretch="Uniform" Width="12" Height="12" Margin="0,0,5,0"/>
                <Slider x:Name="VolumeSlider" Width="60" Minimum="0" Maximum="1" Value="0.5" 
                        VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged"/>
            </StackPanel>

            <!-- Close -->
            <Button Grid.Column="3" Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Style="{StaticResource ModernButtonStyle}" Padding="5">
                <Path Data="{StaticResource CloseIconGeometry}" Fill="#44FFFFFF" Stretch="Uniform" Width="8" Height="8"/>
            </Button>
        </Grid>
    </Border>
</local:WaheeWidgetBase>
