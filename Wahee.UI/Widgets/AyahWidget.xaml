<local:WaheeWidgetBase x:Class="Wahee.UI.Widgets.AyahWidget"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:local="clr-namespace:Wahee.UI.Widgets"
                        Title="آية اليوم"
                        Width="450"
                        Height="320"
                        MinWidth="420"
                        MinHeight="290"
                        MaxHeight="560"
                        WindowStartupLocation="Manual"
                        Topmost="False"
                        AllowsTransparency="True"
                        WindowStyle="None"
                        Background="Transparent"
                        FlowDirection="RightToLeft">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="{DynamicResource BackgroundMainBrush}" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <TextBlock Text="آية عشوائية" Foreground="{DynamicResource TextHeaderBrush}" FontSize="12" FontFamily="Segoe UI Semibold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="PinButton"
                            Click="PinButton_Click"
                            Content="تثبيت"
                            Style="{StaticResource ModernButtonStyle}"
                            FontSize="10"
                            Padding="6,3"
                            Margin="0,0,4,0"
                            Background="#18FFFFFF"
                            Foreground="{DynamicResource TextForegroundBrush}" />
                    <Button Click="CloseButton_Click"
                            Style="{StaticResource ModernButtonStyle}" Padding="4" Background="Transparent">
                        <Path Data="{StaticResource CloseIconGeometry}" Fill="{DynamicResource TextMutedBrush}" Stretch="Uniform" Width="9" Height="9"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="#16FFFFFF" CornerRadius="12" Padding="12" Margin="0,8,0,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="AyahTextBlock" Text="... جاري التحميل ..."
                               Foreground="{DynamicResource TextForegroundBrush}" FontSize="22" TextAlignment="Center"
                               TextWrapping="Wrap" LineHeight="34" FontFamily="Cairo, Segoe UI Semibold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" x:Name="SourceTextBlock" Text=""
                               Foreground="{DynamicResource AccentHighlightBrush}" FontSize="13"
                               TextAlignment="Center" Margin="0,8,0,6" FontFamily="Segoe UI"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="PlayBtn" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Margin="4" Click="PlayBtn_Click">
                            <Path x:Name="PlayIconPath" Data="{StaticResource PlayIconGeometry}" Fill="{DynamicResource AccentBrush}" Stretch="Uniform" Width="15" Height="15"/>
                        </Button>
                        <Button x:Name="RefreshBtn" Style="{StaticResource ModernButtonStyle}" Background="Transparent" Margin="4" Click="RefreshBtn_Click">
                            <Path Data="M12,4V1L8,5L12,9V6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12H4A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z"
                                  Fill="{DynamicResource AccentBrush}" Stretch="Uniform" Width="15" Height="15"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Height="1" Background="#2EFFFFFF" Margin="2,2,2,8" />

            <Border Grid.Row="3" Background="#16FFFFFF" CornerRadius="12" Padding="12" Margin="0,0,0,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="التفسير الميسر" Foreground="{DynamicResource AccentBrush}"
                               FontWeight="Bold" Margin="0,0,0,6" FontFamily="Segoe UI Semibold"/>
                    <TextBlock x:Name="TafsirHintText" Grid.Row="1" Margin="0,0,0,6"
                               Foreground="#FFC58F00" FontSize="10" Visibility="Collapsed"
                               Text="التفسير موجود، كبّر الودجيت لقراءة النص كاملًا."/>
                    <ScrollViewer x:Name="TafsirScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TafsirTextBlock" Text="..."
                                   Foreground="{DynamicResource TextForegroundBrush}" FontSize="12"
                                   TextWrapping="Wrap" FontFamily="Cairo" LineHeight="20"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ProgressBar x:Name="LoadingBar" Grid.Row="4" IsIndeterminate="True" Height="2"
                         Visibility="Collapsed" Margin="0,4,0,0" Background="Transparent"
                         Foreground="{DynamicResource AccentBrush}"/>
        </Grid>
    </Border>
</local:WaheeWidgetBase>
