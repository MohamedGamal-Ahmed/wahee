<local:WaheeWidgetBase x:Class="Wahee.UI.Widgets.PrayerWidget"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:local="clr-namespace:Wahee.UI.Widgets"
                        Title="مواقيت الصلاة"
                        Height="400" Width="300"
                        WindowStartupLocation="Manual"
                        Topmost="False"
                        AllowsTransparency="True"
                        WindowStyle="None"
                        Background="Transparent"
                        FlowDirection="RightToLeft">
    
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8"/>
        </Storyboard>
    </Window.Resources>
    
    <Border x:Name="MainBorder" Background="{DynamicResource BackgroundMainBrush}" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource AccentBrush}" Width="35" Height="35" CornerRadius="10">
                        <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                              Fill="White" Stretch="Uniform" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="مواقيت الصلاة" VerticalAlignment="Center" Margin="10,0,0,0" 
                               Foreground="{DynamicResource TextForegroundBrush}" FontSize="18" FontWeight="SemiBold" FontFamily="Segoe UI Semibold"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Click="CloseButton_Click" 
                        Style="{StaticResource ModernButtonStyle}" Padding="5" Background="Transparent">
                    <Path Data="{StaticResource CloseIconGeometry}" 
                          Fill="White" Stretch="Uniform" Width="10" Height="10"/>
                </Button>
            </Grid>

            <!-- Countdown -->
            <StackPanel Grid.Row="1" Margin="0,20,0,10" HorizontalAlignment="Center">
                <TextBlock x:Name="NextPrayerTxt" Text="الصلاة القادمة: ..." Foreground="{DynamicResource TextHeaderBrush}" FontSize="12" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CountdownTxt" Text="--:--:--" Foreground="{DynamicResource AccentHighlightBrush}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Segoe UI Semibold"/>
            </StackPanel>

            <!-- Prayer List -->
            <ItemsControl x:Name="PrayerListControl" Grid.Row="2" Margin="0,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" Padding="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding NameAr}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="16" FontFamily="Segoe UI Semibold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Time}" Foreground="{DynamicResource TextHeaderBrush}" FontSize="16" FontFamily="Segoe UI"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Footer Location -->
            <TextBlock x:Name="LocationTxt" Grid.Row="3" Text="جاري تحديد الموقع..." Foreground="#66FFFFFF" FontSize="10" HorizontalAlignment="Center" FontStyle="Italic" Margin="0,10,0,0"/>
        </Grid>
    </Border>
</local:WaheeWidgetBase>
