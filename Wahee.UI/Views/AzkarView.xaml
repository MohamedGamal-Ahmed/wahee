<UserControl x:Class="Wahee.UI.Views.AzkarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="700"
             FlowDirection="RightToLeft">
    
    <UserControl.Resources>
        <!-- Tab Button Style -->
        <Style x:Key="AzkarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="30,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" 
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Type Selector -->
        <Border Background="#0AFFFFFF" CornerRadius="16" Padding="10" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="MorningTab" Style="{StaticResource AzkarTabStyle}" 
                             Content="☀️ أذكار الصباح" IsChecked="True" Click="TypeTab_Click"/>
                <RadioButton x:Name="EveningTab" Style="{StaticResource AzkarTabStyle}" 
                             Content="🌙 أذكار المساء" Margin="10,0,0,0" Click="TypeTab_Click"/>
            </StackPanel>
        </Border>

        <!-- Azkar Content -->
        <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}">
            <Grid>
                <!-- Loading -->
                <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" VerticalAlignment="Top" 
                             Height="3" Visibility="Collapsed"/>

                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Counter Badge -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock x:Name="CounterTxt" Text="0 / 1" FontSize="18" 
                                   Foreground="{DynamicResource AccentHighlightBrush}" 
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ReferenceTxt" Text="المرجع" FontSize="12" 
                                   Foreground="#66FFFFFF" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Zikr Text -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="#0AFFFFFF" CornerRadius="16" Padding="30" 
                                MouseLeftButtonUp="ZikrCard_Click" Cursor="Hand">
                            <TextBlock x:Name="ZikrTextBlock" TextWrapping="Wrap" FontSize="24" 
                                       Foreground="{DynamicResource TextForegroundBrush}" TextAlignment="Center" LineHeight="48"
                                       FontFamily="Traditional Arabic"/>
                        </Border>
                    </ScrollViewer>

                    <!-- Tap Hint -->
                    <TextBlock Grid.Row="2" Text="اضغط على الذكر للتسبيح" FontSize="12" 
                               Foreground="#44FFFFFF" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Progress & Navigation -->
        <Border Grid.Row="2" Background="#0AFFFFFF" CornerRadius="16" Padding="15" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Previous Button -->
                <Button Style="{StaticResource ModernButtonStyle}" Background="#22FFFFFF" 
                        Padding="20,10" Click="Previous_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" 
                              Fill="White" Stretch="Uniform" Width="16" Height="16"/>
                        <TextBlock Text="السابق" Foreground="{DynamicResource TextForegroundBrush}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Progress -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                    <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100" Value="0"
                                 Background="#22FFFFFF" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock x:Name="ProgressTxt" Text="1 من 10" FontSize="12" 
                               Foreground="#88FFFFFF" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Next Button -->
                <Button Grid.Column="2" Style="{StaticResource ModernButtonStyle}" 
                        Background="{DynamicResource AccentBrush}" Padding="20,10" Click="Next_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="التالي" Foreground="{DynamicResource TextForegroundBrush}" Margin="0,0,8,0"/>
                        <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" 
                              Fill="White" Stretch="Uniform" Width="16" Height="16"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
