<UserControl x:Class="Wahee.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="600"
             FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600" HorizontalAlignment="Right" Margin="10">
            
            <!-- Notifications Section -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="25" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="🔔 الإشعارات" FontSize="18" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="تنبيهات الأذان" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="إشعار صوتي عند دخول وقت الصلاة" Foreground="#88FFFFFF" FontSize="12"/>
                        </StackPanel>
                        <ToggleButton x:Name="AdhanToggle" Grid.Column="1" Style="{StaticResource ModernToggleStyle}"
                                      IsChecked="True" Checked="AdhanToggle_Changed" Unchecked="AdhanToggle_Changed"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="تذكير الأذكار" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="تذكير بأذكار الصباح والمساء" Foreground="#88FFFFFF" FontSize="12"/>
                        </StackPanel>
                        <ToggleButton x:Name="AzkarReminderToggle" Grid.Column="1" Style="{StaticResource ModernToggleStyle}"
                                      IsChecked="False"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- General Section -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="25" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="⚙️ عام" FontSize="18" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="بدء التشغيل مع ويندوز" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="تشغيل البرنامج تلقائياً عند بدء ويندوز" Foreground="#88FFFFFF" FontSize="12"/>
                        </StackPanel>
                        <ToggleButton x:Name="StartupToggle" Grid.Column="1" Style="{StaticResource ModernToggleStyle}"
                                      IsChecked="False" Checked="StartupToggle_Changed" Unchecked="StartupToggle_Changed"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="التصغير إلى System Tray" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="استمرار عمل البرنامج في الخلفية" Foreground="#88FFFFFF" FontSize="12"/>
                        </StackPanel>
                        <ToggleButton x:Name="TrayToggle" Grid.Column="1" Style="{StaticResource ModernToggleStyle}"
                                      IsChecked="True"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="تحديد الموقع تلقائياً" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="استخدام IP لتحديد مواقيت الصلاة" Foreground="#88FFFFFF" FontSize="12"/>
                        </StackPanel>
                        <ToggleButton x:Name="AutoLocationToggle" Grid.Column="1" Style="{StaticResource ModernToggleStyle}"
                                      IsChecked="True"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Appearance Section -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="25" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="🎨 المظهر" FontSize="18" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="قارئ القرآن الافتراضي" Foreground="{DynamicResource TextForegroundBrush}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ReciterCombo" Grid.Column="1" Width="180" 
                                  Background="#22FFFFFF" Foreground="{DynamicResource TextForegroundBrush}" BorderThickness="0" Padding="10,8">
                            <ComboBoxItem Content="مشاري العفاسي" IsSelected="True"/>
                            <ComboBoxItem Content="عبدالباسط عبدالصمد"/>
                            <ComboBoxItem Content="ماهر المعيقلي"/>
                            <ComboBoxItem Content="سعد الغامدي"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- About Section -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="25" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="ℹ️ عن البرنامج" FontSize="18" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="الإصدار:" Foreground="#88FFFFFF" Width="80"/>
                        <TextBlock Text="1.0.6" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="المطور:" Foreground="#88FFFFFF" Width="80"/>
                        <TextBlock Text="Mohamed Gamal" Foreground="{DynamicResource TextForegroundBrush}"/>
                    </StackPanel>

                    <TextBlock Text="تم التصميم بكل حب لدعم المحتوى الإسلامي الرقمي 💚" 
                               Foreground="{DynamicResource AccentHighlightBrush}" 
                               FontStyle="Italic" TextWrapping="Wrap" Margin="0,10,0,0"/>

                    <Button Content="🌐 زيارة الموقع" Style="{StaticResource ModernButtonStyle}" 
                            Margin="0,15,0,0" HorizontalAlignment="Left" Padding="20,10"
                            Click="VisitWebsite_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
