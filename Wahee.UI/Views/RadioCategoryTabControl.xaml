<UserControl x:Class="Wahee.UI.Views.RadioCategoryTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800"
             FlowDirection="RightToLeft">
    
    <UserControl.Resources>
        <!-- Category Tab Button Style -->
        <Style x:Key="CategoryTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" 
                                CornerRadius="12,12,0,0" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Path x:Name="TabIcon" Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                      Fill="{TemplateBinding Foreground}" Stretch="Uniform" 
                                      Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Radio Card Style -->
        <Style x:Key="RadioCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2" Direction="270" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Featured Cairo Radio -->
        <Border Background="{DynamicResource AccentBrush}" CornerRadius="16" Padding="15" Margin="10,10,10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border Background="#22FFFFFF" Width="50" Height="50" CornerRadius="25" VerticalAlignment="Center">
                    <Path Data="M12,3V13.55C11.41,13.21 10.73,13 10,13A4,4 0 0,0 6,17A4,4 0 0,0 10,21A4,4 0 0,0 14,17V7H18V3H12Z" 
                          Fill="White" Stretch="Uniform" Width="22" Height="22" 
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="⭐ إذاعة القرآن الكريم من القاهرة" Foreground="{DynamicResource TextForegroundBrush}" 
                               FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="بث مباشر على مدار الساعة" Foreground="#CCFFFFFF" FontSize="12"/>
                </StackPanel>
                
                <Button Grid.Column="2" Style="{StaticResource ModernButtonStyle}" 
                        Background="#22FFFFFF" Padding="20,10" Click="PlayCairoRadio_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource PlayIconGeometry}" Fill="White" 
                              Stretch="Uniform" Width="14" Height="14"/>
                        <TextBlock Text="تشغيل" Foreground="{DynamicResource TextForegroundBrush}" Margin="8,0,0,0" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Category Tabs -->
        <Border Grid.Row="1" Background="#0AFFFFFF" CornerRadius="16,16,0,0" Padding="10,10,10,0" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="FavoritesTab" Style="{StaticResource CategoryTabStyle}" 
                             Content="❤️ المفضلة" IsChecked="True" Click="CategoryTab_Click"/>

                <RadioButton x:Name="QuranTab" Style="{StaticResource CategoryTabStyle}" 
                             Content="قرآن كريم" Click="CategoryTab_Click"
                             Tag="M19,2L14,6.5V17.5L19,13V2M6.5,5C4.84,5 3.5,6.34 3.5,8V20C3.5,21.66 4.84,23 6.5,23H17.5C19.16,23 20.5,21.66 20.5,20V8C20.5,6.34 19.16,5 17.5,5H6.5Z"/>
                
                <RadioButton x:Name="RadiosTab" Style="{StaticResource CategoryTabStyle}" 
                             Content="إذاعات" Click="CategoryTab_Click"
                             Tag="{StaticResource RadioIconGeometry}"/>
                
                <RadioButton x:Name="TafsirTab" Style="{StaticResource CategoryTabStyle}" 
                             Content="تفسير" Click="CategoryTab_Click"
                             Tag="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                
                <RadioButton x:Name="AzkarTab" Style="{StaticResource CategoryTabStyle}" 
                             Content="أذكار" Click="CategoryTab_Click"
                             Tag="M12,21.35L10.55,20.03C5.4,15.36 2,12.28 2,8.5C2,5.42 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.09C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.42 22,8.5C22,12.28 18.6,15.36 13.45,20.04L12,21.35Z"/>
            </StackPanel>
        </Border>

        <!-- Player Controls Bar -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Play Controls -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="StopBtn" Style="{StaticResource ModernButtonStyle}" 
                            Background="#EEFF5252" Padding="12,8" Click="Stop_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M18,18H6V6H18V18Z" Fill="White" Stretch="Uniform" Width="12" Height="12"/>
                            <TextBlock Text="إيقاف" Foreground="{DynamicResource TextForegroundBrush}" Margin="8,0,0,0" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Now Playing Info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Border Background="{DynamicResource AccentBrush}" Width="35" Height="35" CornerRadius="8">
                        <Path Data="{StaticResource RadioIconGeometry}" Fill="White" Stretch="Uniform" 
                              Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="NowPlayingTxt" Text="اختر إذاعة للاستماع" 
                                   Foreground="{DynamicResource TextForegroundBrush}" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="NowPlayingCategory" Text="لم يتم التشغيل بعد" 
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Volume -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource VolumeIconGeometry}" Fill="{DynamicResource TextMutedBrush}" 
                          Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0"/>
                    <Slider x:Name="VolumeSlider" Width="80" Minimum="0" Maximum="1" Value="0.7" 
                            VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Row="3" Style="{StaticResource ModernCardStyle}" Margin="0">
            <Grid>
                <!-- Loading Indicator -->
                <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" VerticalAlignment="Top" 
                             Height="3" Visibility="Collapsed"/>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <Path Data="{StaticResource RadioIconGeometry}" Fill="#44FFFFFF" 
                          Stretch="Uniform" Width="60" Height="60" HorizontalAlignment="Center"/>
                    <TextBlock Text="لا توجد محطات في هذا القسم" Foreground="#66FFFFFF" 
                               FontSize="16" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Radios Grid -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl x:Name="RadiosItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RadioCardStyle}" Width="200" Height="120"
                                        MouseLeftButtonUp="RadioCard_Click" Tag="{Binding}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Favorite Button -->
                                        <Button Style="{StaticResource ModernButtonStyle}" 
                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Background="Transparent" Padding="8" Margin="-5,-5,0,0"
                                                Click="FavoriteBtn_Click" Tag="{Binding}"
                                                ToolTip="إضافة/إزالة من المفضلة">
                                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.28 2,8.5C2,5.42 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.09C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.42 22,8.5C22,12.28 18.6,15.36 13.45,20.04L12,21.35Z" 
                                                  Fill="{DynamicResource TextMutedBrush}" Stretch="Uniform" Width="16" Height="16"/>
                                        </Button>
                                        
                                        <Border Background="{DynamicResource AccentBrush}" 
                                                Width="50" Height="50" CornerRadius="25"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="{StaticResource RadioIconGeometry}" Fill="White" 
                                                  Stretch="Uniform" Width="22" Height="22" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <TextBlock Grid.Row="1" Text="{Binding Name}" Foreground="{DynamicResource TextForegroundBrush}" 
                                                   FontSize="13" FontWeight="SemiBold" TextAlignment="Center" 
                                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                   MaxHeight="40" Margin="5,8,5,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
