<UserControl x:Class="Wahee.UI.Views.QuranView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             FlowDirection="RightToLeft">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search & Control -->
        <Border Style="{StaticResource ModernCardStyle}" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Background="#15FFFFFF" CornerRadius="12">
                    <TextBox x:Name="SearchBox" Padding="12" Background="Transparent" Foreground="{DynamicResource TextForegroundBrush}" 
                             BorderThickness="0" Tag="ابحث في القرآن الكريم... (مثلاً: الصبر)" 
                             VerticalContentAlignment="Center" FontFamily="Segoe UI" FontSize="15"
                             GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"
                             KeyUp="SearchBox_KeyUp" Opacity="0.7"/>
                </Border>
                <Button Grid.Column="1" Content="بحث" Style="{StaticResource ModernButtonStyle}" 
                        Padding="25,0" Margin="10,0,0,0" Click="Search_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Surah List -->
            <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Margin="0,0,10,0">
                <ListBox x:Name="SurahListBox" Background="Transparent" BorderThickness="0" 
                         SelectionChanged="SurahListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding NameAr}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Transliteration}" Foreground="#88FFFFFF" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Verses Content -->
            <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <ScrollViewer x:Name="VersesScrollViewer" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="VersesContainer" Margin="20">
                            <!-- Selected Surah Title -->
                            <TextBlock x:Name="SelectedSurahTxt" Text="اختر سورة للبدء" Foreground="{DynamicResource AccentBrush}" 
                                       FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,30"/>
                            
                            <!-- ItemsControl for verses will be here or dynamically added -->
                            <ItemsControl x:Name="VersesListControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" Padding="0,15">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TextAr}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="20" 
                                                           TextWrapping="Wrap" LineHeight="36" FontFamily="Segoe UI" HorizontalAlignment="Right"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                    <TextBlock Text="{Binding Number}" Foreground="{DynamicResource AccentHighlightBrush}" 
                                                               FontSize="12" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource ModernButtonStyle}" 
                                                            Padding="10,2" FontSize="11" Click="PlayAudio_Click" Tag="{Binding}"
                                                            Background="{DynamicResource AccentBrush}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="White" 
                                                                  Stretch="Uniform" Width="10" Height="10"/>
                                                            <TextBlock Text="استماع" Foreground="{DynamicResource TextForegroundBrush}" Margin="5,0,0,0"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Content="تفسير" Style="{StaticResource ModernButtonStyle}" 
                                                            Padding="10,2" FontSize="11" Click="Tafsir_Click" Tag="{Binding}"
                                                            Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" VerticalAlignment="Top" 
                                 Height="4" Visibility="Collapsed"/>

                    <!-- Audio Player Bar -->
                    <Border x:Name="AudioPlayerBar" Grid.Row="1" Background="#15FFFFFF" 
                            CornerRadius="12" Padding="15" Margin="10" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Now Playing Icon -->
                            <Border Background="{DynamicResource AccentBrush}" Width="40" Height="40" CornerRadius="20">
                                <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="White" 
                                      Stretch="Uniform" Width="14" Height="14" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Now Playing Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                <TextBlock x:Name="NowPlayingTxt" Text="جاري التشغيل..." 
                                           Foreground="{DynamicResource TextForegroundBrush}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="NowPlayingSurah" Text="" 
                                           Foreground="#88FFFFFF" FontSize="12"/>
                            </StackPanel>

                            <!-- Stop Button -->
                            <Button Grid.Column="2" Style="{StaticResource ModernButtonStyle}" 
                                    Background="#EEFF5252" Padding="15,8" Click="StopAudio_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M18,18H6V6H18V18Z" Fill="White" 
                                          Stretch="Uniform" Width="12" Height="12"/>
                                    <TextBlock Text="إيقاف" Foreground="{DynamicResource TextForegroundBrush}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
