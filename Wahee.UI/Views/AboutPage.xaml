<UserControl x:Class="Wahee.UI.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             FlowDirection="RightToLeft">
    <Grid Margin="40">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="700">
                <Border Background="{DynamicResource AccentBrush}" CornerRadius="15" Padding="30" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="وحي (Wahee)" FontSize="32" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="Bold" FontFamily="Segoe UI Semibold"/>
                        <TextBlock Text="الإصدار 2.0 - رفيق المسلم الرقمي" FontSize="16" Foreground="#CCFFFFFF" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="عن المشروع" FontSize="22" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <TextBlock Text="وحي هو تطبيق إسلامي لسطح المكتب يجمع مواقيت الصلاة، القرآن، الأذكار، والإذاعات الإسلامية في تجربة عملية يومية." 
                                   FontSize="16" Foreground="{DynamicResource TextForegroundBrush}" TextWrapping="Wrap" LineHeight="28" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="الدعم والمشاركة" FontSize="20" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Content="فحص التحديثات" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,10" Padding="15,8" Click="CheckUpdates_Click"/>
                            <Button Content="الإبلاغ عن مشكلة" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,10" Padding="15,8" Click="ReportBug_Click"/>
                            <Button Content="طلب ميزة" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,10" Padding="15,8" Click="FeatureRequest_Click"/>
                            <Button Content="تقييم التطبيق" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,10" Padding="15,8" Click="RateApp_Click"/>
                        </WrapPanel>
                        <TextBlock Text="روابط الدعم تعمل عبر GitHub Issues/Discussions ويمكن تخصيص رابط التقييم لاحقاً." Foreground="#99FFFFFF" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="الترخيص والحقوق" FontSize="20" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Text="المشروع مفتوح المصدر ويمكن تطويره باستمرار من خلال الإصدارات والتحديثات الرسمية." 
                                   FontSize="14" Foreground="#BBFFFFFF" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                    <TextBlock Text="تم التطوير بواسطة: " Foreground="#88FFFFFF" FontSize="14"/>
                    <TextBlock Text="Mohamed Gamal" Foreground="{DynamicResource TextForegroundBrush}" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
