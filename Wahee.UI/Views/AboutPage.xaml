<UserControl x:Class="Wahee.UI.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             FlowDirection="RightToLeft">
    <Grid Margin="40">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="700">
                <!-- Header -->
                <Border Background="{DynamicResource AccentBrush}" CornerRadius="15" Padding="30" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="وحي (Wahee)" FontSize="32" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="Bold" FontFamily="Segoe UI Semibold"/>
                        <TextBlock Text="الإصدار 2.0 - رفيق المسلم الرقمي" FontSize="16" Foreground="#CCFFFFFF" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- About Secion -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="عن المشروع" FontSize="22" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <TextBlock Text="&quot;وحي&quot; هو نظام ودجات إسلامي مفتوح المصدر لسطح المكتب، صُمم ليكون رفيقاً للمسلم في يومه، يذكره بآيات الله ويربطه بإذاعات القرآن الكريم ومواقيت الصلاة، مع لمسة تصميم عصرية تليق بالمحتوى الإسلامي الرقمي." 
                                   FontSize="16" Foreground="{DynamicResource TextForegroundBrush}" TextWrapping="Wrap" LineHeight="28" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- License & Credits -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="30" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="الترخيص والحقوق" FontSize="20" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Text="هذا المشروع مفتوح المصدر وتحت رخصة MIT. تم استخدام بيانات من مستودع Quran-Data لدعم المحتوى النصي والصوتي." 
                                   FontSize="14" Foreground="#BBFFFFFF" TextWrapping="Wrap" Margin="0,0,0,20"/>
                        
                        <Separator Background="#22FFFFFF" Margin="0,10"/>
                        
                        <TextBlock Text="احتساب الأجر" FontSize="20" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="0,15,0,10"/>
                        <TextBlock Text="هذا العمل خالص لوجه الله تعالى، اللهم اجعل هذا العمل صدقة جارية لي ولوالدي ولأهل بيتي ولكل مسلم ساهم أو دعم أو نشر هذا المشروع." 
                                   FontSize="15" Foreground="{DynamicResource TextForegroundBrush}" FontStyle="Italic" TextWrapping="Wrap" LineHeight="24"/>
                    </StackPanel>
                </Border>

                <!-- Credits -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                    <TextBlock Text="تم التطوير بواسطة: " Foreground="#88FFFFFF" FontSize="14"/>
                    <TextBlock Text="Mohamed Gamal" Foreground="{DynamicResource TextForegroundBrush}" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
