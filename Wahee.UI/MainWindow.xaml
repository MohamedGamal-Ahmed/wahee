<Window x:Class="Wahee.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wahee.UI"
        mc:Ignorable="d"
        Title="وحي (Wahee) - مركز التحكم" Height="700" Width="1100"
        Background="{DynamicResource BackgroundMainBrush}"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Icon="/Assets/Images/app_icon.png">

    <!-- Task Summary:
         - Phase 2 / Task 5: Home page now binds greeting/prayer data to HomeViewModel. -->
    <Grid>
        <Border Background="{DynamicResource IslamicPatternBrush}" Grid.ColumnSpan="2"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="#11FFFFFF" BorderThickness="1,0,0,0">
                <StackPanel Margin="0,40,0,0">
                    <RadioButton x:Name="HomeNavBtn" Style="{StaticResource SidebarButtonStyle}" IsChecked="True" Click="Nav_Click" Tag="Home">
                        <StackPanel>
                            <Path Data="{StaticResource HomeIconGeometry}" Fill="White" Stretch="Uniform" Width="24" Height="24"/>
                            <TextBlock Text="الرئيسية" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI Semibold"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RadiosNavBtn" Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="Radios" Margin="0,15,0,0">
                        <StackPanel>
                            <Path Data="{StaticResource RadioIconGeometry}" Fill="White" Stretch="Uniform" Width="24" Height="24"/>
                            <TextBlock Text="الإذاعات" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI Semibold"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="QuranNavBtn" Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="Quran" Margin="0,15,0,0">
                        <StackPanel>
                            <Path Data="M19,2L14,6.5V17.5L19,13V2M6.5,5C4.84,5 3.5,6.34 3.5,8V20C3.5,21.66 4.84,23 6.5,23H17.5C19.16,23 20.5,21.66 20.5,20V8C20.5,6.34 19.16,5 17.5,5H6.5M6.5,7H17.5C18.05,7 18.5,7.45 18.5,8V18.5L16.03,16.03C15.4,15.4 14.56,15.14 13.72,15.31C12.88,15.47 12.18,16.03 11.83,16.8L11,18.5L10.17,16.8C9.82,16.03 9.12,15.47 8.28,15.31C7.44,15.14 6.6,15.4 5.97,16.03L3.5,18.5V8C3.5,7.45 3.95,7 4.5,7H6.5Z" Fill="White" Stretch="Uniform" Width="24" Height="24"/>
                            <TextBlock Text="البحث" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI Semibold"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="MushafNavBtn" Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="Mushaf" Margin="0,15,0,0">
                        <StackPanel>
                            <Path Data="M18,34.5c0,1.381-1.119,2.5-2.5,2.5H4C2.343,37,1,35.657,1,34V4c0-1.657,1.343-3,3-3h11.5c1.381,0,2.5,1.119,2.5,2.5V34.5z M18,5.1V3.5C18,3.224,17.776,3,17.5,3h-2C15.224,3,15,3.224,15,3.5v1.6H18z M3,34c0,0.552,0.448,1,1,1h11V4H4C3.448,4,3,4.448,3,5V34z" Fill="White" Stretch="Uniform" Width="24" Height="24"/>
                            <TextBlock Text="المصحف" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI Semibold"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="AzkarNavBtn" Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="Azkar" Margin="0,15,0,0">
                        <StackPanel>
                            <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.28 2,8.5C2,5.42 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.09C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.42 22,8.5C22,12.28 18.6,15.36 13.45,20.04L12,21.35Z" Fill="White" Stretch="Uniform" Width="24" Height="24"/>
                            <TextBlock Text="الأذكار" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI Semibold"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="Settings" VerticalAlignment="Bottom" Margin="0,15,0,0">
                        <StackPanel>
                            <Path Data="{StaticResource SettingsIconGeometry}" Fill="White" Stretch="Uniform" Width="24" Height="24"/>
                            <TextBlock Text="الإعدادات" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI Semibold"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="About" VerticalAlignment="Bottom" Margin="0,15,0,0">
                        <StackPanel>
                            <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" Fill="White" Stretch="Uniform" Width="24" Height="24"/>
                            <TextBlock Text="عن البرنامج" Foreground="{DynamicResource TextForegroundBrush}" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI Semibold"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <Grid Grid.Column="0" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,30" Orientation="Horizontal">
                    <Border Background="{DynamicResource AccentBrush}" Width="50" Height="50" CornerRadius="12" Margin="0,0,20,0">
                        <Path Data="{StaticResource HomeIconGeometry}" Fill="White" Stretch="Uniform" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="GreetingTxt" Text="{Binding Greeting}" FontSize="12" Foreground="{DynamicResource AccentHighlightBrush}" FontFamily="Segoe UI Semibold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="HeaderTitle" Text="وحي (Wahee)" FontSize="32" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="Bold" FontFamily="Segoe UI Semibold"/>
                        <TextBlock x:Name="HeaderSubtitle" Text="تطبيقات وإضافات إسلامية لسطح المكتب" FontSize="14" Foreground="{DynamicResource TextHeaderBrush}" FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <Grid x:Name="HomePage" Grid.Row="1" Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="مركز التحكم" FontSize="22" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold" Margin="10,0,0,25" FontFamily="Segoe UI Semibold"/>

                            <UniformGrid Columns="2">
                                <Border Style="{StaticResource ModernCardStyle}" Margin="10" MinHeight="220">
                                    <Grid Margin="30">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Border Background="{DynamicResource AccentBrush}" Width="45" Height="45" CornerRadius="10">
                                                <Path Data="{StaticResource HomeIconGeometry}" Fill="White" Stretch="Uniform" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="آية اليوم" FontSize="20" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0" FontFamily="Segoe UI Semibold"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Text="اجعل آيات القرآن الكريم نصب عينيك دائماً. يتم اختيار آية عشوائية يومياً لإلهامك وتذكيرك." FontSize="14" Foreground="{DynamicResource TextHeaderBrush}" LineHeight="24" TextWrapping="Wrap" Margin="0,0,0,20" FontFamily="Segoe UI"/>

                                        <CheckBox x:Name="AyahToggle" Grid.Row="2" Content="تفعيل إضافة آية اليوم" Style="{StaticResource {x:Type CheckBox}}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="15" Checked="AyahToggle_Checked" Unchecked="AyahToggle_Unchecked" FontFamily="Segoe UI Semibold"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource ModernCardStyle}" Margin="10" MinHeight="220">
                                    <Grid Margin="30">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Border Background="#8A43CDD6" Width="45" Height="45" CornerRadius="10">
                                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" Fill="White" Stretch="Uniform" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="مواقيت الصلاة" FontSize="20" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0" FontFamily="Segoe UI Semibold"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1">
                                            <TextBlock x:Name="NextPrayerNameTxt" Text="{Binding NextPrayerName}" FontSize="18" Foreground="{DynamicResource TextForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,5" FontFamily="Segoe UI Semibold"/>
                                            <TextBlock x:Name="CountdownTxt" Text="{Binding Countdown}" FontSize="14" Foreground="{DynamicResource AccentHighlightBrush}" Margin="0,0,0,10" FontFamily="Segoe UI Semibold"/>
                                            <TextBlock x:Name="LocationTxt" Text="{Binding LocationText}" FontSize="12" Foreground="{DynamicResource TextHeaderBrush}" FontStyle="Italic" FontFamily="Segoe UI" Margin="0,0,0,15"/>
                                            <Button Content="{Binding ErrorMessage}" Command="{Binding RetryCommand}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" Style="{StaticResource ModernButtonStyle}" Background="#55EA580C" Foreground="White" FontSize="11" Margin="0,0,0,8"/>

                                            <CheckBox x:Name="PrayerWidgetToggle" Content="تفعيل ويدجيت المواقيت" Style="{StaticResource {x:Type CheckBox}}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="14" Margin="0,0,0,10" Checked="PrayerWidgetToggle_Checked" Unchecked="PrayerWidgetToggle_Unchecked" FontFamily="Segoe UI Semibold"/>

                                            <CheckBox x:Name="FloatingRadioToggle" Content="تفعيل الراديو العائم" Style="{StaticResource {x:Type CheckBox}}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="14" Checked="FloatingRadioToggle_Checked" Unchecked="FloatingRadioToggle_Unchecked" FontFamily="Segoe UI Semibold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="RadiosPage" Grid.Row="1" Visibility="Collapsed">
                    <ContentControl x:Name="RadiosPageContainer"/>
                </Grid>

                <Grid x:Name="QuranPage" Grid.Row="1" Visibility="Collapsed">
                    <ContentControl x:Name="QuranPageContainer"/>
                </Grid>

                <Grid x:Name="MushafPage" Grid.Row="1" Visibility="Collapsed">
                    <ContentControl x:Name="MushafPageContainer"/>
                </Grid>

                <Grid x:Name="AzkarPage" Grid.Row="1" Visibility="Collapsed">
                    <ContentControl x:Name="AzkarPageContainer"/>
                </Grid>

                <Grid x:Name="SettingsPage" Grid.Row="1" Visibility="Collapsed">
                    <ContentControl x:Name="SettingsPageContainer"/>
                </Grid>

                <ContentControl x:Name="AboutPageContainer" Grid.Row="1" Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
